{
  "manifest_version": 3,
  "name": "web-gateway Browser Bridge",
  "version": "0.1.0",
  "description": "Browser automation bridge for the web-gateway skill. Connects Chrome tabs to a local web-gateway daemon without Chrome remote-debugging prompts.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "web-gateway",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
