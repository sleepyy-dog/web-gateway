{
  "manifest_version": 3,
  "name": "Web-Gateway CDP Transport",
  "version": "0.1.0",
  "description": "CDP transport for Web-Gateway. Sends Chrome DevTools Protocol commands through chrome.debugger without repeated Chrome remote-debugging prompts.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Web-Gateway",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
